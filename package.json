{
  "name": "task-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "dev:lan": "cross-env NODE_ENV=development nodemon src/index.js",
    "dev:tunnel": "concurrently \"cross-env NODE_ENV=development nodemon src/index.js\" \"ngrok http 3000\"",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:ci": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --runInBand --coverage --detectOpenHandles --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "npm prune --production && mkdir -p build && cp -R src build && cp package.json build && cp package-lock.json build && cp .env build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "firebase-admin": "^13.2.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@jest/globals": "^30.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0"
  }
}
